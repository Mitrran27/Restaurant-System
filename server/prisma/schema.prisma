generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  orders     Order[]
  menuItems  MenuItem[]
  inventory  Inventory[]

  @@map("branches")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  phone     String?
  branchId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch        Branch?        @relation(fields: [branchId], references: [id])
  orders        Order[]
  notifications Notification[]
  reviews       Review[]

  @@index([email])
  @@index([branchId])
  @@map("users")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  categoryId  String
  branchId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id])
  branch     Branch?     @relation(fields: [branchId], references: [id])
  inventory  Inventory?
  orderItems OrderItem[]
  reviews    Review[]

  @@index([categoryId])
  @@index([branchId])
  @@map("menu_items")
}

model Inventory {
  id         String   @id @default(uuid())
  menuItemId String   @unique
  branchId   String
  status     StockStatus @default(IN_STOCK)
  quantity   Int      @default(0)
  updatedAt  DateTime @updatedAt

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("inventory")
}

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique
  userId        String?
  branchId      String
  type          OrderType
  status        OrderStatus @default(PENDING)
  tableNumber   String?
  deliveryAddress String?
  notes         String?
  totalAmount   Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user        User?            @relation(fields: [userId], references: [id])
  branch      Branch           @relation(fields: [branchId], references: [id])
  items       OrderItem[]
  payment     Payment?
  statusLogs  OrderStatusLog[]
  review      Review?
  notifications Notification[]

  @@index([branchId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  notes      String?

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amount        Decimal       @db.Decimal(10, 2)
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String?
  orderId   String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user  User?  @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@map("notifications")
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  orderId    String   @unique
  menuItemId String?
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  order    Order     @relation(fields: [orderId], references: [id])
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id])

  @@index([menuItemId])
  @@map("reviews")
}

model OrderStatusLog {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_status_logs")
}

enum Role {
  ADMIN
  CASHIER
  KITCHEN
  CUSTOMER
}

enum OrderType {
  DELIVERY
  PICKUP
  DINE_IN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
}

enum NotificationType {
  ORDER_PLACED
  ORDER_CONFIRMED
  ORDER_PREPARING
  ORDER_READY
  ORDER_DELIVERED
  ORDER_CANCELLED
  GENERAL
}
